/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Local config file for running viralrecon
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines custom process parameters for viralrecon pipeline.

    Use as follows:
        nextflow run nf-core/viralrecon -profile <docker/singularity> -c <this_profile> --input <samplesheet.csv> --outdir <OUTDIR>

----------------------------------------------------------------------------------------
*/

params {
    config_profile_name = 'rsv illumina profile'
    config_profile_description = 'rsv illumina analysis'

    //skip QC
    skip_fastqc = true
    skip_kraken2 = true
    skip_fastp = true
    skip_cutadapt = true

    // Variant calling options
    variant_caller = 'ivar'

    // Assembly options
    skip_assembly = true

    // lineage assignment
    skip_asciigenome = true
    skip_nextclade = true
    skip_pangolin = true

    skip_multiqc = true
}

process {
    withName: BCFTOOLS_NORM {
        ext.args = '--output-type z --multiallelics -any'
        // publishDir = [
        //     path: { "${params.outdir}/variants/bcftools" },
        //     mode: params.publish_dir_mode,
        //     pattern: "*.vcf.gz",
        // ]
    }
    withName: 'IVAR_CONSENSUS' {
                ext.args = '-t 0.75 -q 20 -m 10 -n N'
                ext.args2 = '--count-orphans --no-BAQ --max-depth 0 --min-BQ 0 -aa -ff UNMAP,SECONDARY,QCFAIL' //keep DUP
                ext.prefix = { "${meta.id}.consensus" }
                // publishDir = [
                //     [
                //         path: { "${params.outdir}/variants/${variant_caller}/consensus/ivar" },
                //         mode: params.publish_dir_mode,
                //         pattern: "*.{fa,txt}",
                //     ],
                //     [
                //         path: { "${params.outdir}/variants/${variant_caller}/consensus/ivar" },
                //         mode: params.publish_dir_mode,
                //         pattern: "*.mpileup",
                //         enabled: params.save_mpileup
                //     ]
                // ]
            }
}
